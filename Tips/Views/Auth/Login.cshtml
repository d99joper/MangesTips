@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin – Logga in</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 60px auto; max-width: 340px; }
        input { display: block; width: 100%; margin-bottom: 10px; padding: 6px; box-sizing: border-box; }
        .error { color: red; }
    </style>
</head>
<body>
    <h2>Admin – Logga in</h2>
    @if (!string.IsNullOrEmpty(ViewBag.Error as string))
    {
        <p class="error">@ViewBag.Error</p>
    }
    @using (Html.BeginForm("Login", "Auth", new { returnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <label>Användarnamn</label>
        <input type="text" name="username" autofocus />
        <label>Lösenord</label>
        <input type="password" name="password" />
        <input type="submit" value="Logga in" />
    }
</body>
</html>
